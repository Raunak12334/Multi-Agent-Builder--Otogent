generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id
  name                String
  email               String        @unique
  emailVerified       Boolean       @default(false)
  image               String?
  role                Role          @default(USER)
  onboardingCompleted Boolean       @default(false)
  organizationId      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @default(now()) @updatedAt
  deletedAt           DateTime?
  accounts            Account[]
  sessions            Session[]
  invitesSent         TeamInvite[]  @relation("InvitedBy")
  organization        Organization? @relation(fields: [organizationId], references: [id])
  supportTickets      SupportTicket[]

  @@index([organizationId])
  @@map("user")
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  companySize  String?
  useCase      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  deletedAt    DateTime?
  credentials  Credential[]
  subscription Subscription?
  teamInvites  TeamInvite[]
  users        User[]
  workflows    Workflow[]
  supportTickets SupportTicket[]

  @@map("organization")
}

model Subscription {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  plan              Plan         @default(FREE)
  freeTierStartedAt DateTime?
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
  deletedAt         DateTime?
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model TeamInvite {
  id             String       @id @default(cuid())
  email          String
  tokenHash      String       @unique
  organizationId String
  invitedById    String
  role           Role         @default(USER)
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime
  used           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@map("team_invite")
}

model AuditLog {
  id             String    @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  metadata       Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  @@index([organizationId, createdAt])
}

model Session {
  id        String    @id
  expiresAt DateTime
  token     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  ipAddress String?
  userAgent String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  deletedAt  DateTime?

  @@map("verification")
}

model Credential {
  id             String         @id @default(cuid())
  name           String
  value          String?
  type           CredentialType
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  organizationId String
  accessLevel    String?
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  rotationCount  Int            @default(0)
  accessRoles    String[]
  lastRotatedAt  DateTime?
  valueEncrypted String?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  Node           Node[]

  @@index([organizationId, type])
  @@map("credential")
}

model Workflow {
  id             String            @id @default(cuid())
  name           String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  organizationId String
  currentVersion Int               @default(1)
  isLocked       Boolean           @default(false)
  webhookSecret  String?           @unique
  connections    Connection[]
  executions     Execution[]
  nodes          Node[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions       WorkflowVersion[]

  @@index([organizationId, updatedAt])
  @@map("workflow")
}

model WorkflowVersion {
  id           String    @id @default(cuid())
  workflowId   String
  version      Int
  name         String
  nodes        Json
  createdAt    DateTime  @default(now())
  connections  Json
  deprecatedAt DateTime?
  isActive     Boolean   @default(true)
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("workflow_version")
}

model Node {
  id                String          @id @default(cuid())
  workflowId        String
  name              String
  type              NodeType
  position          Json
  data              Json            @default("{}")
  credentialId      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  config            Json?
  delayMs           Int?
  prompt            String?
  url               String?
  outputConnections Connection[]    @relation("FromNode")
  inputConnections  Connection[]    @relation("ToNode")
  credential        Credential?     @relation(fields: [credentialId], references: [id])
  workflow          Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeExecutions    NodeExecution[]

  @@index([workflowId, type])
  @@index([credentialId])
  @@map("node")
}

model Connection {
  id         String    @id @default(cuid())
  workflowId String
  fromNodeId String
  toNodeId   String
  fromOutput String    @default("main")
  toInput    String    @default("main")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  fromNode   Node      @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     Node      @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, fromOutput, toInput])
  @@map("connection")
}

model Execution {
  id             String                @id @default(cuid())
  workflowId     String
  status         ExecutionStatus       @default(RUNNING)
  error          String?
  errorStack     String?
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  inngestEventId String
  deletedAt      DateTime?
  output         Json?
  archivedAt     DateTime?
  idempotencyKey String?
  maxRetries     Int                   @default(3)
  retryCount     Int                   @default(0)
  versionUsed    Int?
  lastRetryAt    DateTime?
  priority       Int                   @default(0)
  queueStatus    QueueStatus           @default(QUEUED)
  retryStrategy  String                @default("exponential")
  scheduledAt    DateTime?
  workflow       Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  checkpoints    ExecutionCheckpoint[]
  nodeExecutions NodeExecution[]

  @@index([workflowId, status, startedAt])
  @@index([status, queueStatus, scheduledAt])
  @@index([workflowId, startedAt])
  @@index([queueStatus, priority, scheduledAt])
  @@index([status, retryCount])
  @@index([inngestEventId])
  @@index([idempotencyKey])
  @@map("execution")
}

model ExecutionCheckpoint {
  id              String         @id @default(cuid())
  executionId     String
  nodeId          String?
  sequence        Int
  state           Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  archivedAt      DateTime?
  error           String?
  nodeType        NodeType?
  durationMs      Int?
  nodeExecutionId String?
  retryAttempt    Int            @default(0)
  execution       Execution      @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeExecution   NodeExecution? @relation(fields: [nodeExecutionId], references: [id])

  @@unique([executionId, sequence])
  @@index([executionId, createdAt])
  @@index([executionId, nodeId, sequence])
  @@index([nodeExecutionId])
  @@map("execution_checkpoint")
}

model NodeExecution {
  id          String                @id @default(cuid())
  executionId String
  nodeId      String
  status      NodeStatus            @default(PENDING)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  retryCount  Int                   @default(0)
  error       String?
  output      Json?
  archivedAt  DateTime?
  attempt     Int                   @default(1)
  checkpoints ExecutionCheckpoint[]
  execution   Execution             @relation(fields: [executionId], references: [id], onDelete: Cascade)
  node        Node                  @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([executionId, nodeId, attempt])
  @@index([executionId, status])
  @@index([executionId, nodeId])
  @@index([nodeId, startedAt])
  @@index([executionId, startedAt])
  @@index([status, retryCount])
  @@index([executionId, attempt])
  @@map("node_execution")
}

model RateLimitBucket {
  id             String   @id @default(cuid())
  organizationId String
  limitType      String
  count          Int      @default(0)
  limit          Int
  resetAt        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, limitType, resetAt])
  @@index([organizationId, limitType])
  @@map("rate_limit_bucket")
}

model ExecutionAuditLog {
  id             String    @id @default(cuid())
  executionId    String
  organizationId String
  action         String
  details        Json?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?
  archivedAt     DateTime?

  @@index([executionId])
  @@index([organizationId, createdAt])
  @@index([executionId, createdAt])
  @@map("execution_audit_log")
}

model SupportTicket {
  id             String         @id @default(cuid())
  userId         String
  organizationId String?
  subject        String
  description    String
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("support_ticket")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CredentialType {
  OPENAI
  ANTHROPIC
  GEMINI
  GEMMA
  HUGGINGFACE
}

enum NodeType {
  INITIAL
  MANUAL_TRIGGER
  WEBHOOK_TRIGGER
  HTTP_REQUEST
  ROUTER
  CONDITION
  HUMAN_APPROVAL
  SET_VARIABLE
  TEXT_TEMPLATE
  JSON_TRANSFORM
  DELAY
  MERGE
  LOGGER
  GEMMA
  GOOGLE_FORM_TRIGGER
  STRIPE_TRIGGER
  ANTHROPIC
  GEMINI
  OPENAI
  HUGGINGFACE
  DISCORD
  SLACK
  X
  LINKEDIN
  INSTAGRAM
  TELEGRAM
  GOOGLE_SHEETS
  EMAIL_SEND
  EMAIL_PARSER
  SCHEDULE
  DB_QUERY
  FILE_STORAGE
  TWILIO_SMS
  HUBSPOT
  SHOPIFY
}

enum ExecutionStatus {
  RUNNING
  WAITING_APPROVAL
  SUCCESS
  FAILED
}

enum QueueStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum NodeStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRIED
}
